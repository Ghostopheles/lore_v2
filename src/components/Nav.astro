---
import { AUTHOR } from "../config/author";
---
<nav>
  <div class="nav-inner">

    <!-- Left: logo placeholder + site name -->
    <a href="/" class="nav-brand">
      <div class="logo-mark" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="28" height="28" rx="7" fill="url(#nav-logo-grad)"/>
          <path d="M14 8v12M8 14h12M10.34 10.34l7.32 7.32M17.66 10.34l-7.32 7.32"
                stroke="rgba(255,255,255,0.85)" stroke-width="1.5" stroke-linecap="round"/>
          <defs>
            <linearGradient id="nav-logo-grad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#7c3aed"/>
              <stop offset="100%" stop-color="#3b82f6"/>
            </linearGradient>
          </defs>
        </svg>
      </div>
      <span class="site-name">Ghost's Lore</span>
    </a>

    <!-- Center: Pagefind search -->
    <div class="nav-search">
      <div id="search"></div>
    </div>

    <!-- Right: social icon links -->
    <div class="nav-socials">
      <iframe src="https://github.com/sponsors/Ghostopheles/button" title="Sponsor Ghostopheles" height="32" width="114" style="border: 0; border-radius: 6px;"/>
      {AUTHOR.socials.map((s) => (
        <a href={s.href} class="social-link" target="_blank" rel="noopener noreferrer" aria-label={s.label}>
          {s.icon === "x" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          )}
          {s.icon === "bluesky" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 600 530" fill="currentColor" aria-hidden="true">
              <path d="M135.72 44.03C202.216 93.951 273.74 195.17 300 249.49c26.262-54.316 97.782-155.54 164.28-205.46C512.26 8.009 590-19.862 590 68.825c0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.3884-3.6904-10.832-3.7077-7.8964-.0173-2.9357-1.1937.5076-3.7077 7.8964-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.4489-163.25-81.433C20.15 217.613 9.9912 86.54 9.9912 68.825c0-88.687 77.742-60.816 125.73-24.795z"/>
            </svg>
          )}
          {s.icon === "github" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          )}
        </a>
      ))}
    </div>

  </div>
</nav>

<!-- Initialize Pagefind UI (script tag loaded at runtime; gracefully absent in dev) -->
<script is:inline>
  (function () {
    var s = document.createElement("script");
    s.src = "/pagefind/pagefind-ui.js";
    s.onload = function () {
      new PagefindUI({ element: "#search", showImages: false, excerptLength: 12 });
      document.addEventListener("click", function (e) {
        var searchEl = document.getElementById("search");
        if (!searchEl || searchEl.contains(e.target)) return;
        var input = searchEl.querySelector(".pagefind-ui__search-input");
        if (input && input.value) {
          input.value = "";
          input.dispatchEvent(new Event("input", { bubbles: true }));
        }
      });
    };
    s.onerror = function () { /* search index not built yet (dev mode) */ };
    document.head.appendChild(s);
  })();
</script>

<style>
  nav {
    padding: var(--space-3) 0;
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(8, 11, 18, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  nav::after {
    content: "";
    display: block;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(135deg, #7c3aed 0%, #3b82f6 100%);
    opacity: 0.3;
  }

  .nav-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--padding-x);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
  }

  /* ── Left: brand ── */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    min-width: 0;
  }

  .logo-mark {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .site-name {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .nav-brand:hover .site-name {
    color: var(--color-text);
    text-decoration: none;
  }

  /* ── Center: search ── */
  .nav-search {
    width: clamp(180px, 30vw, 440px);
  }

  /* ── Right: socials ── */
  .nav-socials {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    justify-content: flex-end;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 7px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .social-link:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.06);
    text-decoration: none;
  }

  /* ── Mobile: collapse search, 2-zone layout ── */
  @media (max-width: 600px) {
    .nav-inner {
      grid-template-columns: 1fr auto;
    }
    .nav-search {
      display: none;
    }
  }
</style>
