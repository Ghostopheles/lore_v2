---
import Head from "../components/Head.astro";
import Nav from "../components/Nav.astro";
import AuthorCard from "../components/AuthorCard.astro";

interface Props {
  title: string;
  description?: string;
  pubDate: string;
  tags?: string[];
  readingTime: number;
}

const { title, description, pubDate, tags, readingTime } = Astro.props;

const formatted = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(new Date(pubDate));
---
<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} />
  </head>
  <body>
    <div class="starfield"></div>
    <Nav />
    <main>
      <article>
        <header>
          <a href="/" class="back-link">← All posts</a>
          <h1>{title}</h1>
          <div class="post-meta">
            <time datetime={pubDate}>{formatted}</time>
            <span class="meta-sep">·</span>
            <span class="reading-time">{readingTime} min read</span>
          </div>
          <AuthorCard />
          {tags && tags.length > 0 && (
            <div class="tag-list post-header-tags">
              {tags.map((tag) => (
                <a href={`/tags/${tag}/`} class="tag-chip">{tag}</a>
              ))}
            </div>
          )}
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>
    </main>
    <footer>
      <div class="footer-inner">
        <span>&copy; {new Date().getFullYear()} lore.ghst.tools</span>
      </div>
    </footer>
  </body>
</html>

<style>
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--space-10) var(--padding-x) var(--space-24);
  }

  article {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 0 var(--space-16);
    align-items: start;
  }

  /* ── Sidebar (header) ────────────────────────── */
  header {
    position: sticky;
    top: calc(4rem + var(--space-6));
    padding-right: var(--space-8);
    border-right: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-text-faint);
    text-decoration: none;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-6);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent-1);
    text-decoration: none;
  }

  h1 {
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-3xl));
    font-weight: 700;
    line-height: var(--leading-snug);
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
    margin-bottom: var(--space-1);
  }

  .meta-sep {
    opacity: 0.5;
  }

  .post-header-tags {
    margin-top: var(--space-4);
    justify-content: flex-start;
  }

  /* ── Prose (content) ─────────────────────────── */
  .prose {
    min-width: 0; /* prevent grid blowout on long words */
  }

  /* ── Footer ──────────────────────────────────── */
  footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-8) 0;
    position: relative;
    z-index: 1;
    margin-top: var(--space-8);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--padding-x);
    color: var(--color-text-faint);
    font-size: var(--text-sm);
  }

  /* ── Mobile: stack sidebar above content ─────── */
  @media (max-width: 768px) {
    article {
      grid-template-columns: 1fr;
      gap: var(--space-8) 0;
    }

    header {
      position: static;
      padding-right: 0;
      border-right: none;
      padding-bottom: var(--space-6);
      border-bottom: 1px solid var(--color-border);
    }

    h1 {
      font-size: var(--text-2xl);
    }
  }
</style>
