---
import MainLayout from "../components/MainLayout.astro";
import { AUTHOR } from "../config/author";
---

<MainLayout title="Links — lore.ghst.tools" description="Socials, projects, and tools from Ghostopheles.">
  <div class="links-page">

    <section class="section">
      <h2 class="section-title">Socials</h2>
      <div class="link-list">
        {AUTHOR.socials.map((s) => (
          <a href={s.href} class="link-card" target="_blank" rel="noopener noreferrer">
            <span class="link-icon">
              {s.icon === "x" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {s.icon === "bluesky" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 600 530" fill="currentColor" aria-hidden="true">
                  <path d="M135.72 44.03C202.216 93.951 273.74 195.17 300 249.49c26.262-54.316 97.782-155.54 164.28-205.46C512.26 8.009 590-19.862 590 68.825c0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.3884-3.6904-10.832-3.7077-7.8964-.0173-2.9357-1.1937.5076-3.7077 7.8964-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.4489-163.25-81.433C20.15 217.613 9.9912 86.54 9.9912 68.825c0-88.687 77.742-60.816 125.73-24.795z"/>
                </svg>
              )}
              {s.icon === "github" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
              )}
            </span>
            <span class="link-label">{s.label}</span>
            <span class="link-arrow">↗</span>
          </a>
        ))}
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section">
      <h2 class="section-title">Projects &amp; Tools</h2>
      <div class="link-list">
        <a href="#" class="link-card placeholder">
          <span class="link-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M9 3v18M3 9h6M3 15h6"/>
            </svg>
          </span>
          <span class="link-label">Coming soon</span>
        </a>
      </div>
    </section>

  </div>
</MainLayout>

<style>
  .links-page {
    max-width: 560px;
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .section-title {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
  }

  .section-divider {
    height: 1px;
    background: var(--color-border);
    margin: var(--space-10) 0;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: rgba(124, 58, 237, 0.04);
    color: var(--color-text);
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast), color var(--transition-fast);
  }

  .link-card:hover {
    border-color: rgba(124, 58, 237, 0.45);
    background: rgba(124, 58, 237, 0.08);
    color: var(--color-text);
    text-decoration: none;
  }

  .link-card.placeholder {
    opacity: 0.4;
    cursor: default;
    pointer-events: none;
  }

  .link-icon {
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .link-label {
    flex: 1;
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .link-arrow {
    font-size: var(--text-sm);
    color: var(--color-text-faint);
    transition: color var(--transition-fast);
  }

  .link-card:hover .link-arrow {
    color: var(--color-accent-1);
  }
</style>
